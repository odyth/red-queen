# GitHub Personal Access Token (fine-grained recommended).
# See https://github.com/settings/personal-access-tokens/new
# Required scopes: Contents/Issues/Pull requests/Workflows (read+write), Metadata (read).
GITHUB_PAT=

# Optional: webhook HMAC secret. Only needed if you've configured webhooks
# in the repo settings. Polling works without this.
GITHUB_WEBHOOK_SECRET=
