{
  "name": "redqueen",
  "version": "0.1.0",
  "description": "Deterministic orchestrator for AI coding agents — zero tokens, full SDLC pipeline, human-in-the-loop gates.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "redqueen": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node scripts/copy-assets.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "tsc -p tsconfig.build.json && eslint src/ && prettier --check src/",
    "test": "vitest",
    "test:ci": "vitest --run --passWithNoTests",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "ai",
    "orchestrator",
    "claude",
    "sdlc",
    "automation",
    "developer-tools",
    "cli"
  ],
  "author": "Odyth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odyth/red-queen.git"
  },
  "homepage": "https://redqueen.sh",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "better-sqlite3": "^12.9.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
